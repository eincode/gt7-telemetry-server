{
  "name": "gt7-telemetry-server",
  "version": "0.1.0",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "mock": "MOCK=true tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "record": "tsx src/recorder/cli.ts",
    "bundle": "node scripts/bundle.mjs",
    "package:win": "pkg dist-bundled/server.cjs --target node20-win-x64 --output release/gt7-server.exe && pkg dist-bundled/cli.cjs --target node20-win-x64 --output release/gt7-record.exe",
    "dist:win": "yarn bundle && yarn package:win"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
